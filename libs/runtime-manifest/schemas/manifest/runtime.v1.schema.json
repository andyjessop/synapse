{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "libs/runtime-manifest/schemas/manifest/runtime.v1.schema.json",
  "title": "Synapse runtime manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "name", "agents"],
  "properties": {
    "version": { "const": 1 },
    "schema": {
      "const": "libs/runtime-manifest/schemas/manifest/runtime.v1.schema.json"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    },
    "webhooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/webhookMount" }
    },
    "pollers": {
      "type": "array",
      "items": { "$ref": "#/$defs/pollMount" }
    },
    "adapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/adapterMount" }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "webhookMount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "enum": [
            "synapse.webhooks.prs.v1",
            "synapse.webhooks.example-echo-ping.v1",
            "synapse.webhooks.example-notifier-ticket.v1"
          ]
        }
      }
    },
    "pollMount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "enum": ["synapse.poll.example-in-memory-heartbeat.v1"]
        },
        "intervalMs": { "type": "integer", "minimum": 10000 },
        "lockTtlMs": { "type": "integer", "minimum": 1 },
        "enabled": { "type": "boolean" },
        "params": { "type": "object" }
      }
    },
    "adapterMount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Adapter source id; must be registered in apps/adapters"
        }
      }
    }
  }
}
