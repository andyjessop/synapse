{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "libs/runtime-manifest/schemas/scenario/run-loop.v1.schema.json",
  "title": "Synapse scenario run-loop file",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "scenarios"],
  "properties": {
    "version": { "const": 1 },
    "schema": {
      "const": "libs/runtime-manifest/schemas/scenario/run-loop.v1.schema.json"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "fixtureValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["file"],
          "properties": {
            "file": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["data"],
          "properties": {
            "data": {}
          }
        }
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "method", "returns"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "returns": { "$ref": "#/$defs/fixtureValue" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "manifests", "ingress"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "manifests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Runtime manifest name values (manifest.name) this scenario may run under"
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "fixtures"],
          "properties": {
            "source": { "type": "string", "minLength": 1 },
            "fixtures": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/fixtureValue" }
            }
          }
        },
        "adapters": {
          "type": "array",
          "items": { "$ref": "#/$defs/adapter" }
        },
        "terminalEventTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
