{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "libs/runtime-manifest/schemas/adapter/gitlab.fetchChanges.v1.schema.json",
  "title": "GitLab fetchChanges adapter fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "adapter", "method", "match", "response"],
  "properties": {
    "version": { "const": 1 },
    "schema": {
      "const": "libs/runtime-manifest/schemas/adapter/gitlab.fetchChanges.v1.schema.json"
    },
    "adapter": { "const": "gitlab" },
    "method": { "const": "fetchChanges" },
    "match": {
      "type": "object",
      "additionalProperties": true
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "merge_request_iid", "changes"],
      "properties": {
        "project_id": { "type": "integer", "minimum": 1 },
        "merge_request_iid": { "type": "integer", "minimum": 1 },
        "merge_request_id": { "type": "integer", "minimum": 1 },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["old_path", "new_path", "diff"],
            "properties": {
              "old_path": { "type": "string" },
              "new_path": { "type": "string" },
              "a_mode": { "type": "string" },
              "b_mode": { "type": "string" },
              "diff": { "type": "string" },
              "new_file": { "type": "boolean" },
              "renamed_file": { "type": "boolean" },
              "deleted_file": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
