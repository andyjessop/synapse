{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dev (worker inspect)",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "restart": true,
      "timeout": 120000,
      "preLaunchTask": "synapse-dev-worker-inspect",
      "skipFiles": ["<node_internals>/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    }
  ]
}
